{
    "name": "@mudravaorg/mcp-server",
    "version": "1.1.0",
    "type": "module",
    "description": "PixelFixer MCP server – exposes kanban tasks, GitHub context, and AI actions to MCP-compatible AI agents (Claude, Cursor, VS Code, Windsurf)",
    "keywords": [
        "mcp",
        "model-context-protocol",
        "pixelfixer",
        "kanban",
        "bug-tracking",
        "ai-agent",
        "claude",
        "cursor",
        "vscode"
    ],
    "license": "MIT",
    "author": "Mudrava <hello@mudrava.com> (https://mudrava.com)",
    "homepage": "https://github.com/Mudrava/pixelfixer-mcp-server#readme",
    "repository": {
        "type": "git",
        "url": "https://github.com/Mudrava/pixelfixer-mcp-server.git"
    },
    "bugs": {
        "url": "https://github.com/Mudrava/pixelfixer-mcp-server/issues"
    },
    "bin": {
        "pixelfixer-mcp": "./dist/index.js"
    },
    "main": "./dist/index.js",
    "files": [
        "dist",
        "README.md",
        "LICENSE"
    ],
    "engines": {
        "node": ">=18"
    },
    "scripts": {
        "build": "tsc",
        "dev": "tsc --watch",
        "typecheck": "tsc --noEmit",
        "test": "vitest run",
        "test:watch": "vitest",
        "clean": "rimraf dist",
        "prepublishOnly": "npm run clean && npm run build"
    },
    "dependencies": {
        "@modelcontextprotocol/sdk": "^1.12.1",
        "zod": "^3.24.0"
    },
    "devDependencies": {
        "@pixelfixer/config-typescript": "workspace:*",
        "@types/node": "^22.15.0",
        "rimraf": "^6.0.0",
        "typescript": "^5.7.0",
        "vitest": "^4.0.18"
    }
}
